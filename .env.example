# Application
NODE_ENV=development
PORT=8080
API_VERSION=v1

# Supabase Database
# DATABASE_URL: pooled connection (pgBouncer, port 6543) — used at runtime.
# connection_limit keeps each dyno's Prisma pool small so N dynos don't exhaust Supabase.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10
# DIRECT_URL: direct connection (port 5432) — used only by prisma migrate.
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase API (optional - if using Supabase Auth/Storage)
# New key format: publishable (safe for clients) + secret (server-only, bypasses RLS)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
SUPABASE_JWKS_URL=https://[project-ref].supabase.co/auth/v1/.well-known/jwks.json

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting (token bucket)
# Default per-IP bucket: burst = MAX_REQUESTS, refilling MAX_REQUESTS per WINDOW_MS.
# Login/refresh have tighter per-route buckets (@RateLimit decorator).
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Storage — DigitalOcean Spaces (S3-compatible)
STORAGE_PROVIDER=do_spaces
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=gridlearnia
# Optional: CDN edge endpoint for public reads (enable CDN on the Space)
# DO_SPACES_CDN_ENDPOINT=https://gridlearnia.nyc3.cdn.digitaloceanspaces.com

# Email Service (optional)
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@yourdomain.com

# Platform SUPER_ADMIN bootstrap (required in production for the first seed;
# development falls back to superadmin@gridlearnia.dev / password123)
# SEED_SUPERADMIN_EMAIL=admin@yourdomain.com
# SEED_SUPERADMIN_PASSWORD=change-me

# Gate for `npm run admin:create -- <email>` (creates/promotes SUPER_ADMINs).
# The script prompts for this value interactively.
PLATFORM_ADMIN_SECRET=generate-a-long-random-value

# Optional: Slack/Discord-compatible webhook pinged on critical audit events
# (SUPER_ADMIN created, ORGANIZATION_ADMIN granted/revoked, school approved)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Logging
LOG_LEVEL=info
